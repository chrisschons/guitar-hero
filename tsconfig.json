{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "strict": false,
    "allowJs": true,
    "checkJs": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": [
      "vite/client"
    ],
    "baseUrl": "./src",
    "paths": { "@/*": ["./*"] }
  },
  "include": [
    "src",
    "vite.config.*",
    "vitest.config.*",
    "playwright.config.*",
    "tsconfig.json"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
